{
  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN",
    "group_id": -100YOUR_GROUP_ID,
    "allowed_user_ids": []
  },
  "paths": {
    "store_path": "./data/telecode.json",
    "logs_dir": "./data/logs"
  },
  "streaming": {
    "interval_sec": 0.8,
    "max_message_length": 3800,
    "idle_timeout_sec": 1800
  },
  "voice": {
    "stt": {
      "enabled": false,
      "base_url": "http://localhost:6600/v1",
      "model": "whisper-1"
    }
  },
  "capture": {
    "image_interval": 15,
    "video_interval": 60
  },
  "mcp_server": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 1236,
    "cors_origins": [],
    "tts_url": "http://127.0.0.1:6500",
    "stt_url": "http://127.0.0.1:6600"
  },
  "proxy": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 1235,
    "upstream_url": "http://localhost:1234",
    "debug": false,
    "tool_search": false,
    "strip_reminders": false,
    "auto_load_tools": false,
    "lift_tool_result_images": false,
    "location": "",
    "core_tools": ["Bash", "Edit", "Read", "Write", "Glob", "Grep", "Agent", "Skill"],
    "cors_origins": [],
    "model_mapping": {
      "claude-opus-4-6": "your-local-model-id",
      "claude-sonnet-4-6": "your-local-model-id"
    },
    "client_profiles": [
      {
        "name": "office",
        "match": {"header": "Referer", "contains": "pivot.claude.ai"},
        "system_instruction": "office.md",
        "tool_search": false,
        "inject_date_location": false,
        "inject_managed": ["code_execution"],
        "strip_tool_types": ["web_search_*", "code_execution_*"]
      },
      {
        "name": "claude-code",
        "match": {"header": "User-Agent", "contains": "claude-cli"},
        "system_instruction": "system.md",
        "tool_search": true,
        "inject_date_location": true,
        "core_tools": ["Bash", "Edit", "Read", "Write", "Glob", "Grep", "Agent", "Skill"],
        "inject_managed": ["WebSearch", "speak", "transcribe"],
        "strip_cache_control": false
      }
    ],
    "web_search": {
      "enabled": false
    }
  },
  "tools": {
    "claude": {
      "name": "Claude Code",
      "icon": "\ud83d\udfe3",
      "startup_cmd": ["claude"],
      "flags": ["--dangerously-skip-permissions"],
      "env": {
        "ANTHROPIC_API_KEY": ""
      },
      "session": {
        "resume_id": ""
      }
    },
    "claude-local": {
      "name": "Claude Code (Local)",
      "icon": "\ud83d\udfe4",
      "startup_cmd": ["claude"],
      "flags": ["--dangerously-skip-permissions", "--max-turns", "100"],
      "env": {
        "ANTHROPIC_BASE_URL": "http://localhost:1235",
        "ANTHROPIC_AUTH_TOKEN": "lmstudio",
        "ANTHROPIC_MODEL": "your-model-name",
        "DISABLE_PROMPT_CACHING": "1"
      },
      "session": {
        "resume_id": ""
      }
    },
    "codex": {
      "name": "Codex CLI",
      "icon": "\ud83d\udfe2",
      "startup_cmd": ["codex"],
      "flags": [],
      "env": {"OPENAI_API_KEY": ""},
      "session": {}
    },
    "codex-local": {
      "name": "Codex CLI (Local)",
      "icon": "\ud83d\udfe0",
      "startup_cmd": ["codex"],
      "flags": ["--oss", "-m", "qwen3.5-9b"],
      "env": {},
      "session": {}
    },
    "shell": {
      "name": "Bash",
      "icon": "\ud83d\udc1a",
      "startup_cmd": ["bash", "--norc", "--noprofile"],
      "flags": [],
      "env": {},
      "session": {}
    },
    "powershell": {
      "name": "PowerShell",
      "icon": "\ud83d\udd37",
      "startup_cmd": ["powershell.exe", "-NoProfile", "-NoLogo"],
      "flags": [],
      "env": {},
      "session": {}
    },
    "computer": {
      "name": "Computer Control",
      "icon": "\ud83d\udda5\ufe0f",
      "api": {
        "base_url": "http://localhost:1234/v1",
        "api_key": "lm-studio",
        "model": "your-vision-model",
        "format": "openai"
      },
      "capture_interval": 3,
      "max_history": 20,
      "system_prompt": ""
    }
  }
}
