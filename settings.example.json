{
  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN",
    "group_id": -100YOUR_GROUP_ID,
    "allowed_user_ids": []
  },

  "paths": {
    "store_path": "./data/telecode.json",
    "logs_dir": "./data/logs"
  },

  "streaming": {
    "interval_sec": 0.8,
    "max_message_length": 3800,
    "idle_timeout_sec": 1800,
    "idle_sec": 2.0,
    "max_wait_sec": 5.0
  },

  "voice": {
    "stt": {
      "enabled": false,
      "base_url": "http://localhost:6600/v1",
      "model": "whisper-1"
    }
  },

  "capture": {
    "image_interval": 15,
    "video_interval": 60
  },

  "mcp_server": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 1236,
    "cors_origins": [],
    "tts_url": "http://127.0.0.1:6500",
    "stt_url": "http://127.0.0.1:6600"
  },

  "docgraph": {
    "binary": "",

    "host": {
      "enabled": false,
      "auto_start": false,
      "auto_restart": true,
      "host": "127.0.0.1",
      "port": 5500,
      "gpu": false,
      "directml_device_id": -1,
      "debounce": 500
    },

    "roots": [
      { "path": "", "watch": false }
    ],

    "llm": {
      "model": "",
      "host": "localhost",
      "port": 1235,
      "format": "openai",
      "max_tokens": 150,
      "max_tokens_wiki": 4096,
      "docstrings": false,
      "wiki": false,
      "prompts": {
        "docstring": "",
        "wiki": ""
      }
    },

    "embeddings": {
      "model": "",
      "gpu": false
    },

    "rerank": {
      "model": "",
      "default": false,
      "gpu": false
    },

    "index": {
      "workers": 0,
      "embed_batch_size": 0,
      "documents": {
        "enabled": false,
        "text_extensions": [],
        "asset_extensions": []
      }
    },

    "wiki": {
      "depth": 12
    }
  },

  "llamacpp": {
    "enabled": false,
    "binary": "llama-server",
    "host": "127.0.0.1",
    "port": 1234,
    "auto_start": false,
    "idle_unload_sec": 300,
    "ready_timeout_sec": 120,
    "api_key": "",

    "default_model": "your-model",

    "threads": 12,
    "threads_batch": 0,
    "batch_size": 2048,
    "ubatch_size": 512,
    "parallel": 1,
    "cont_batching": true,

    "mlock": false,
    "no_mmap": false,

    "main_gpu": 0,
    "tensor_split": "",
    "split_mode": "layer",
    "numa": "",

    "seed": -1,
    "keep": 0,

    "kv_offload": true,
    "kv_unified": false,
    "cache_prompt": true,
    "clear_idle": false,
    "cache_ram": 0,
    "swa_full": false,
    "ctx_checkpoints": 0,
    "checkpoint_every_n_tokens": 0,
    "defrag_thold": 0,
    "slot_save_path": "",

    "spec_type": "",
    "spec_ngram_size_n": 0,
    "spec_ngram_size_m": 0,
    "spec_ngram_min_hits": 0,
    "threads_draft": 0,
    "threads_batch_draft": 0,

    "models": {
      "your-model": {
        "path": "/absolute/path/to/model.gguf",
        "mmproj": "",
        "preload": false,

        "ctx_size": 32768,
        "n_gpu_layers": 99,

        "flash_attn": true,

        "cache_type_k": "f16",
        "cache_type_v": "f16",
        "cache_reuse": 256,

        "n_cpu_moe": 0,
        "cpu_moe": false,

        "rope_scaling": "",
        "rope_freq_base": 0,
        "rope_freq_scale": 0,
        "yarn_orig_ctx": 0,

        "chat_template": "",
        "jinja": true,

        "draft_model": "",
        "ctx_size_draft": 0,
        "n_gpu_layers_draft": 0,
        "cache_type_k_draft": "",
        "cache_type_v_draft": "",
        "device_draft": "",
        "draft_n": 5,
        "draft_n_min": 0,
        "draft_p_min": 0.75,
        "lookup_cache_static": "",
        "lookup_cache_dynamic": "",

        "lora": "",
        "lora_scale": 1.0,

        "grammar": "",
        "grammar_file": "",

        "extra_args": [
          ["--example-extra-flag", "value"]
        ],

        "inference_defaults": {
          "temperature": 0.6,
          "top_p": 0.95,
          "top_k": 20,
          "presence_penalty": 1.0,
          "reasoning": {
            "enabled": true,
            "start": "<think>",
            "end": "</think>",
            "emit_thinking_blocks": true
          }
        }
      }
    },

    "inference": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0,
      "repeat_penalty": 1.0,
      "presence_penalty": 0.0,
      "frequency_penalty": 0.0,
      "max_tokens": null,
      "stop": [],
      "context_overflow": "truncate_middle",
      "disable_thinking": false,

      "reasoning": {
        "enabled": true,
        "start": "<think>",
        "end": "</think>",
        "emit_thinking_blocks": true
      },

      "reasoning_effort_map": {
        "none":    {"enable_thinking": false, "thinking_budget_tokens": 0},
        "minimal": {"enable_thinking": false, "thinking_budget_tokens": 0},
        "low":     {"thinking_budget_tokens": 1024,  "reasoning_effort": "low"},
        "medium":  {"thinking_budget_tokens": 4096,  "reasoning_effort": "medium"},
        "high":    {"thinking_budget_tokens": 16384, "reasoning_effort": "high"},
        "xhigh":   {"thinking_budget_tokens": 65536, "reasoning_effort": "high"},
        "max":     {"thinking_budget_tokens": 0,     "reasoning_effort": "high"}
      },

      "structured_output": { "enabled": false, "schema": null, "grammar": null }
    },

    "extra_args": []
  },

  "proxy": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 1235,
    "protocols": ["anthropic", "openai"],
    "debug": false,

    "tool_search": false,
    "strip_reminders": false,
    "auto_load_tools": false,
    "location": "",
    "max_roundtrips": 15,
    "ping_interval": 10,

    "core_tools": ["Bash", "Edit", "Read", "Write", "Glob", "Grep", "Agent", "Skill"],
    "cors_origins": [],

    "model_mapping": {
      "claude-opus-4-6": "your-model",
      "claude-sonnet-4-6": "your-model"
    },

    "client_profiles": [
      {
        "name": "e2e-test",
        "match": {"header": "User-Agent", "contains": "telecode-e2e"},
        "tool_search": false,
        "inject_date_location": false,
        "strip_reminders": false,
        "auto_load_tools": false,
        "inject_managed": []
      },
      {
        "name": "office",
        "match": {"header": "Referer", "contains": "pivot.claude.ai"},
        "system_instruction": "office.md",
        "tool_search": false,
        "inject_date_location": false,
        "strip_reminders": false,
        "auto_load_tools": false,
        "core_tools": [],
        "inject_managed": ["code_execution", "web_search"],
        "strip_tool_names": []
      },
      {
        "name": "claude-code",
        "match": {"header": "User-Agent", "contains": "claude-cli"},
        "system_instruction": "system.md",
        "tool_search": true,
        "inject_date_location": true,
        "strip_reminders": true,
        "auto_load_tools": true,
        "core_tools": ["Bash", "Edit", "Read", "Write", "Glob", "Grep", "Agent", "Skill"],
        "inject_managed": [
          "web_search"
        ],
        "strip_tool_names": []
      }
    ]
  },

  "tools": {
    "claude": {
      "name": "Claude Code",
      "icon": "\ud83d\udfe3",
      "startup_cmd": ["claude"],
      "flags": ["--dangerously-skip-permissions"],
      "env": { "ANTHROPIC_API_KEY": "" },
      "session": { "resume_id": "" }
    },
    "claude-local": {
      "name": "Claude Code (Local)",
      "icon": "\ud83d\udfe4",
      "startup_cmd": ["claude"],
      "flags": ["--dangerously-skip-permissions", "--max-turns", "100"],
      "env": {
        "ANTHROPIC_BASE_URL": "http://localhost:1235",
        "ANTHROPIC_AUTH_TOKEN": "local",
        "ANTHROPIC_MODEL": "your-model",
        "DISABLE_PROMPT_CACHING": "1"
      },
      "session": { "resume_id": "" }
    },
    "codex": {
      "name": "Codex CLI",
      "icon": "\ud83d\udfe2",
      "startup_cmd": ["codex"],
      "flags": [],
      "env": {"OPENAI_API_KEY": ""},
      "session": {}
    },
    "codex-local": {
      "name": "Codex CLI (Local)",
      "icon": "\ud83d\udfe0",
      "startup_cmd": ["codex"],
      "flags": ["--oss", "-m", "qwen3.5-9b"],
      "env": {},
      "session": {}
    },
    "shell": {
      "name": "Bash",
      "icon": "\ud83d\udc1a",
      "startup_cmd": ["bash", "--norc", "--noprofile"],
      "flags": [],
      "env": {},
      "session": {},
      "streaming": { "idle_sec": 0.5, "max_wait_sec": 2.5 }
    },
    "powershell": {
      "name": "PowerShell",
      "icon": "\ud83d\udd37",
      "startup_cmd": ["powershell.exe", "-NoProfile", "-NoLogo"],
      "flags": [],
      "env": {},
      "session": {},
      "streaming": { "idle_sec": 0.5, "max_wait_sec": 2.5 }
    },
    "computer": {
      "name": "Computer Control",
      "icon": "\ud83d\udda5\ufe0f",
      "api": {
        "base_url": "http://localhost:1235/v1",
        "api_key": "local",
        "model": "your-model",
        "format": "openai"
      },
      "capture_interval": 3,
      "max_history": 20,
      "system_prompt": ""
    }
  }
}
